#!/usr/bin/env lua5.4
-- Nova runner: parse a .nova file, transpile it to Lua, execute it.
-- Usage: ./nova <file.nova> [--entry name] [int args...]
--   --entry  function to call (default: main)
--   int args are passed to that function
--
-- `import`ing a luarocks package uses Lua's normal module search, so set up
-- your rock tree the usual way (e.g. `eval "$(luarocks path)"`). C rocks are
-- built per Lua version, so run under the Lua the rock was built for.

local here = arg[0]:match("^(.*)/[^/]*$") or "."
package.path = here .. "/lang/?.lua;" .. here .. "/codegen/?.lua;"
            .. package.path

local Parser = require("parser")
local Avon = require("avon")

local file, entry, callargs = nil, "main", {}
local i = 1
while i <= #arg do
  local a = arg[i]
  if a == "--entry" then
    entry = arg[i + 1]; i = i + 2
  elseif not file then
    file = a; i = i + 1
  else
    local n = tonumber(a)
    if not n then error("argument is not an integer: " .. a) end
    callargs[#callargs + 1] = n; i = i + 1
  end
end

if not file then
  io.stderr:write("usage: nova <file.nova> [--entry name] [int args...]\n")
  os.exit(1)
end

local fh, openerr = io.open(file, "r")
if not fh then
  io.stderr:write("nova: cannot open " .. file .. ": " .. openerr .. "\n")
  os.exit(1)
end
local src = fh:read("*a")
fh:close()

-- The whole parse -> transpile -> run pipeline runs inside one pcall, so any
-- error() raised in the toolchain, a missing entry, or an uncaught Nova throw
-- is caught and reported cleanly.
local ok, result = pcall(function()
  local ast = Parser:new(src):parse()

  -- validate the entry point with a helpful list of what's available
  local funcs = {}
  for _, node in ipairs(ast.body) do
    if node.type == "function" then funcs[node.name] = true end
  end
  if not funcs[entry] then
    local names = {}
    for name in pairs(funcs) do names[#names + 1] = name end
    table.sort(names)
    error(string.format("no function '%s' (available: %s)",
      entry, #names > 0 and table.concat(names, ", ") or "none"))
  end

  -- pad missing entry args to the entry's arity with 0: avon may drop a
  -- parameter's default when every internal call site supplies it, so the
  -- runner keeps the "missing args -> 0" contract for the entry itself.
  for _, node in ipairs(ast.body) do
    if node.type == "function" and node.name == entry then
      for j = #callargs + 1, #node.params do callargs[j] = 0 end
      break
    end
  end

  -- host builtins exposed to Nova code, mirroring the old VM stdlib. The
  -- transpiled Lua calls them by global name, so they live in the chunk's
  -- environment. `import foo` binds the module table as the global `foo`
  -- (so foo.fn(...) is plain Lua indexing); `import foo as f` binds it as f.
  -- math is taken from globals, anything else is require()d, so luarocks
  -- packages work the same way.
  local env = {pow = function(a, b) return a ^ b end}
  env.print = function(...) print(...) return 0 end
  for _, name in ipairs({"sqrt", "floor", "ceil", "sin", "cos", "log"}) do
    env[name] = math[name]
  end
  for _, node in ipairs(ast.body) do
    if node.type == "import" then
      env[node.alias or node.module] =
        _G[node.module] or require(node.module)
    end
  end

  -- transpile the AST to Lua and load it; the entry is a real Lua function
  local unpack = table.unpack or unpack -- 5.2+ vs 5.1/LuaJIT
  local mods = Avon.load(ast.body, env)
  return {mods[entry](unpack(callargs))}
end)

if not ok then
  local msg
  if type(result) == "table" and result.nova then
    msg = "uncaught throw: " .. tostring(result.value)
  else
    -- strip Lua's "file:line:" prefix so the message reads as a Nova error
    msg = tostring(result):gsub("^.-:%d+: ", "")
  end
  io.stderr:write("nova: " .. file .. ": " .. msg .. "\n")
  os.exit(1)
end

print(result[1] or 0)
