#!/usr/bin/env lua
-- Nova runner: parse a .nova file, lower it to pseudo-IR, execute it.
-- Usage: ./nova <file.nova> [--entry name] [int args...]
--   --entry  function to call (default: main)
--   int args are passed to that function

local here = arg[0]:match("^(.*)/[^/]*$") or "."
package.path = here .. "/lang/?.lua;" .. here .. "/codegen/?.lua;"
            .. package.path

-- make luarocks-installed modules importable without any env vars: add the
-- user rock tree for the running Lua version to the search paths
local home = os.getenv("HOME")
local ver = _VERSION:match("(%d+%.%d+)")
if home and ver then
  package.path = home .. "/.luarocks/share/lua/" .. ver .. "/?.lua;"
    .. home .. "/.luarocks/share/lua/" .. ver .. "/?/init.lua;" .. package.path
  package.cpath = home .. "/.luarocks/lib/lua/" .. ver .. "/?.so;" .. package.cpath
end

local Parser = require("parser")
local Codegen = require("codegen")
local VM = require("vm")

local file, entry, callargs = nil, "main", {}
local i = 1
while i <= #arg do
  local a = arg[i]
  if a == "--entry" then
    entry = arg[i + 1]; i = i + 2
  elseif not file then
    file = a; i = i + 1
  else
    local n = tonumber(a)
    if not n then error("argument is not an integer: " .. a) end
    callargs[#callargs + 1] = n; i = i + 1
  end
end

if not file then
  io.stderr:write("usage: nova <file.nova> [--entry name] [int args...]\n")
  os.exit(1)
end

local fh, openerr = io.open(file, "r")
if not fh then
  io.stderr:write("nova: cannot open " .. file .. ": " .. openerr .. "\n")
  os.exit(1)
end
local src = fh:read("*a")
fh:close()

-- Nova has no try/catch of its own; it does not need one. The host (Lua)
-- already provides structured error handling via pcall, so the whole
-- parse -> codegen -> run pipeline runs inside one, and any error() raised
-- in the toolchain or a missing entry is caught and reported cleanly.
local ok, result = pcall(function()
  local ast = Parser:new(src):parse()

  -- validate the entry point with a helpful list of what's available
  local funcs = {}
  for _, node in ipairs(ast.body) do
    if node.type == "function" then funcs[node.name] = true end
  end
  if not funcs[entry] then
    local names = {}
    for name in pairs(funcs) do names[#names + 1] = name end
    table.sort(names)
    error(string.format("no function '%s' (available: %s)",
      entry, #names > 0 and table.concat(names, ", ") or "none"))
  end

  local cg = Codegen.new()
  local insns = cg:generate(ast.body)
  local vm = VM.new(insns, cg.strings)

  -- `import foo` in the source exposes that module's functions to Nova as
  -- foo.fn(...). A stdlib table (math) is taken from the globals; anything
  -- else is require()d, so luarocks packages work the same way.
  for _, node in ipairs(ast.body) do
    if node.type == "import" then
      local m = _G[node.module] or require(node.module)
      for k, v in pairs(m) do
        if type(v) == "function" then vm:register(node.module .. "." .. k, v) end
      end
    end
  end

  return vm:run(entry, callargs)
end)

if not ok then
  local msg
  if type(result) == "table" and result.nova then
    msg = "uncaught throw: " .. tostring(result.value)
  else
    -- strip Lua's "file:line:" prefix so the message reads as a Nova error
    msg = tostring(result):gsub("^.-:%d+: ", "")
  end
  io.stderr:write("nova: " .. file .. ": " .. msg .. "\n")
  os.exit(1)
end

print(result[1] or 0)
